# Copy to .env and fill in real values (never commit .env)

# MySQL
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=fall_detection
DB_USER=root
DB_PASSWORD=change-me

# Auth & API
SECRET_KEY=change-me-to-a-long-random-string

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_IDS=
APPLE_CLIENT_ID=
ALLOW_UNVERIFIED_SOCIAL_LOGIN=true

# Email (optional)
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@example.com

# Admin (comma-separated emails)
ADMIN_EMAILS=

# CORS (comma-separated origins, or *)
CORS_ORIGINS=*

# Features
USE_MOCK_DATA=true
EXPOSE_DOCS=false
ENABLE_PUSH_ALERTS=true
ENABLE_SMS_ALERTS=false

# Expo push (optional)
EXPO_ACCESS_TOKEN=

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# MQTT (optional; see app/services/mqtt_service.py)
MQTT_ENABLED=false
MQTT_BROKER=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPICS=fall-detection/device-data

# Device online window (seconds)
DEVICE_ONLINE_WINDOW_SECONDS=120
