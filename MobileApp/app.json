{
  "expo": {
    "name": "Fall Detection",
    "slug": "fall-detection-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.falldetection.app",
      "infoPlist": {
        "NSContactsUsageDescription": "يحتاج التطبيق للوصول إلى جهات الاتصال لاستيراد جهات الاتصال الطارئة.",
        "NSLocationWhenInUseUsageDescription": "يحتاج التطبيق للوصول إلى موقعك لإرسال الموقع في حالات الطوارئ.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "يحتاج التطبيق للوصول إلى موقعك باستمرار لمراقبة حالة السقوط.",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification"
        ],
        "NSCameraUsageDescription": "يحتاج التطبيق للوصول إلى الكاميرا لمسح الرمز الشريطي للجهاز.",
        "NSFaceIDUsageDescription": "يحتاج التطبيق إلى Face ID للمصادقة البيومترية."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.falldetection.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_CONTACTS",
        "android.permission.CALL_PHONE",
        "android.permission.SEND_SMS",
        "android.permission.VIBRATE",
        "android.permission.WRITE_CONTACTS",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-font",
      "expo-location",
      "expo-contacts",
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "يحتاج التطبيق للوصول إلى الكاميرا لمسح الرمز الشريطي للجهاز."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d33adc67-9b40-45a7-ba77-c1f3907a62ab"
      }
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/your-project-id"
    },
    "newArchEnabled": false,
    "owner": "aysha-kassems-organization"
  }
}
