{
  "expo": {
    "name": "Fall Detection",
    "slug": "fall-detection-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "extra": {
      "apiUrl": "http://192.168.1.11:8000/api/v1",
      "useMock": true,
      "supportsRTL": true
    },
    
    "ios": {
      "supportsRTL": true,
      "supportsTablet": true,
      "bundleIdentifier": "com.falldetection.app",
      "infoPlist": {
        "NSContactsUsageDescription": "يحتاج التطبيق للوصول إلى جهات الاتصال لاستيراد جهات الاتصال الطارئة.",
        "NSLocationWhenInUseUsageDescription": "يحتاج التطبيق للوصول إلى موقعك لإرسال الموقع في حالات الطوارئ.",
        "NSLocationAlwaysUsageDescription": "يحتاج التطبيق للوصول إلى موقعك باستمرار لمراقبة حالة السقوط.",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification"
        ],
        "NSCameraUsageDescription": "يحتاج التطبيق للوصول إلى الكاميرا لمسح الرمز الشريطي للجهاز.",
        "NSFaceIDUsageDescription": "يحتاج التطبيق إلى Face ID للمصادقة البيومترية."
      }
    },
    
    "android": {
      "supportsRTL": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.falldetection.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_CONTACTS",
        "android.permission.CALL_PHONE",
        "android.permission.SEND_SMS",
        "android.permission.VIBRATE"
      ]
    },
    
    "web": {
      "favicon": "./assets/favicon.png"
    },
    
    "plugins": [
      "expo-location",
      "expo-contacts",
      "expo-notifications"
    ]
  }
}